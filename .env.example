# Agent identity and auth
AGENT_ID=ubuntu-vm-001
AGENT_TOKEN=change-me

# Local standalone capture
# On Ubuntu, prefer explicit interface name (example: eth0, ens33).
AGENT_INTERFACE=
AGENT_LOG_DIR=anomalyx-logs

# Relay/dashboard server endpoint
RELAY_URL=http://localhost:8600

# Enable host enforcement and logs
IPS_ENFORCEMENT_ENABLED=1
IPS_DROP_TTL_SEC=120
IPS_BLOCK_TTL_SEC=3600
IPS_ENABLE_REVERSE_DNS=0
IPS_ENFORCEMENT_LOG_PATH=anomalyx-logs/enforcement_actions.log
IPS_ALLOWLIST_IPS=
IPS_ALLOWLIST_CIDRS=
IPS_MAX_NEW_BLOCKS_PER_MIN=120
IPS_TEMP_BLOCK_REPEAT_SUPPRESS_SEC=20
IPS_BLOCK_REPEAT_SUPPRESS_SEC=180

# Staged escalation controls
IPS_ESCALATION_ENABLED=1
IPS_ESCALATION_WINDOW_SEC=300
IPS_ESCALATE_TO_TEMP_BLOCK_HITS=4
IPS_ESCALATE_TO_BLOCK_HITS=12
IPS_BLOCK_MIN_RISK=90

# Dashboard relay auth token (for running the public dashboard server)
DASHBOARD_SERVER_TOKEN=change-me
# Admin token for dashboard-side unblock actions (defaults to DASHBOARD_SERVER_TOKEN if empty).
DASHBOARD_ADMIN_TOKEN=change-me

# Security controls for dashboard relay
DASHBOARD_STRICT_AUTH=1
DASHBOARD_RATE_LIMIT_PER_MIN=1800
DASHBOARD_MAX_BODY_BYTES=262144
DASHBOARD_TIMESTAMP_SKEW_SEC=120
# Set explicit allowed origin for browser requests. Leave empty for same-origin.
DASHBOARD_ALLOWED_ORIGIN=

# Agent transport tuning
AGENT_REQUEST_TIMEOUT_SEC=6
AGENT_MAX_RETRIES=3
AGENT_MAX_EVENTS_PER_CYCLE=8
AGENT_MIN_RISK_TO_RELAY=0

# Optional: use a custom external model folder instead of packaged model files.
# ANOMALYX_MODEL_DIR=C:/path/to/models
